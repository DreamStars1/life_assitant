# === Life Assistant 环境变量模板 ===
# 复制此文件为 backend/.env 并填入真实值
# 复制此文件为 .env 用于 docker compose 变量插值

# Domain
DOMAIN=localhost

# Used by the backend to generate links in emails (e.g. password reset)
FRONTEND_HOST=http://localhost:5173

# Environment: local, staging, production
ENVIRONMENT=local

# Backend
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173,http://app.localhost"
SECRET_KEY=<changeme>
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=<changeme>

# Emails
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# MySQL
MYSQL_SERVER=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=app
MYSQL_USER=app
MYSQL_PASSWORD=<changeme>
MYSQL_ROOT_PASSWORD=<changeme>

# Redis（用于应用的分布式缓存/锁，不含 compose 中的 redis 服务密码）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PWD=<changeme>

# Docker Compose 变量插值
TAG=latest
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONT=front

SENTRY_DSN=
